generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  VIP
  ADMIN
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  WIN
  LOSS
  REFERRAL_BONUS
  AIRDROP
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
}

enum GameType {
  COINFLIP
  CRASH
  JACKPOT
}

enum GameStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum Chain {
  SOLANA
  ETHEREUM
}

model User {
  id              String   @id @default(cuid())
  email           String?  @unique
  username        String   @unique
  passwordHash    String?
  avatar          String?
  role            Role     @default(USER)
  balance         Float    @default(0)
  totalWagered    Float    @default(0)
  totalWon        Float    @default(0)
  totalLost       Float    @default(0)
  gamesPlayed     Int      @default(0)
  neonCoins       Float    @default(0)
  solBalance      Float    @default(0)
  referralCode    String   @unique @default(cuid())
  referredBy      String?
  isVerified      Boolean  @default(false)
  isBanned        Boolean  @default(false)
  lastSeen        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  wallets          Wallet[]
  transactions     Transaction[]
  coinflipGames    CoinflipGame[]
  crashBets        CrashBet[]
  jackpotEntries   JackpotEntry[]
  referrals        Referral[]      @relation("Referrer")
  referredByUser   Referral?       @relation("Referred")
  sessions         Session[]
  profile          UserProfile?
  achievements     UserAchievement[]
  unlockedThemes   UserTheme[]

  @@index([username])
  @@index([referralCode])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String
  chain     Chain
  address   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chain, address])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

model Transaction {
  id        String            @id @default(cuid())
  userId    String
  type      TransactionType
  amount    Float
  currency  String            @default("USDC")
  chain     Chain?
  txHash    String?           @unique
  status    TransactionStatus @default(PENDING)
  note      String?
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model CoinflipGame {
  id           String     @id @default(cuid())
  userId       String
  betAmount    Float
  choice       String     // "heads" | "tails"
  result       String     // "heads" | "tails"
  winAmount    Float      @default(0)
  multiplier   Float      @default(2)
  serverSeed   String
  clientSeed   String
  nonce        Int
  hashResult   String
  status       GameStatus @default(COMPLETED)
  createdAt    DateTime   @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
}

model CrashRound {
  id           String     @id @default(cuid())
  multiplier   Float?
  serverSeed   String     @unique
  serverSeedHash String
  crashPoint   Float
  status       GameStatus @default(ACTIVE)
  startedAt    DateTime   @default(now())
  endedAt      DateTime?

  bets CrashBet[]

  @@index([status])
  @@index([startedAt])
}

model CrashBet {
  id               String     @id @default(cuid())
  userId           String
  crashRoundId     String
  betAmount        Float
  cashoutMultiplier Float?
  winAmount        Float      @default(0)
  autoCashout      Float?
  status           GameStatus @default(ACTIVE)
  createdAt        DateTime   @default(now())

  user       User       @relation(fields: [userId], references: [id])
  crashRound CrashRound @relation(fields: [crashRoundId], references: [id])

  @@index([userId])
  @@index([crashRoundId])
}

model JackpotRound {
  id           String     @id @default(cuid())
  poolAmount   Float      @default(0)
  winnerId     String?
  serverSeed   String     @unique
  serverSeedHash String
  ticketTotal  Float      @default(0)
  status       GameStatus @default(ACTIVE)
  startedAt    DateTime   @default(now())
  endedAt      DateTime?

  entries JackpotEntry[]

  @@index([status])
}

model JackpotEntry {
  id             String   @id @default(cuid())
  userId         String
  jackpotRoundId String
  betAmount      Float
  ticketStart    Float
  ticketEnd      Float
  color          String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  jackpotRound JackpotRound @relation(fields: [jackpotRoundId], references: [id])

  @@index([jackpotRoundId])
  @@index([userId])
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referredId  String   @unique
  earnings    Float    @default(0)
  createdAt   DateTime @default(now())

  referrer User @relation("Referrer", fields: [referrerId], references: [id])
  referred User @relation("Referred", fields: [referredId], references: [id])

  @@index([referrerId])
}

model GameSeed {
  id         String   @id @default(cuid())
  serverSeed String   @unique
  seedHash   String   @unique
  revealed   Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model UserProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  bio          String?  @db.VarChar(300)
  website      String?
  twitter      String?
  discord      String?
  themeId      String   @default("purple")
  avatarUrl    String?
  bannerUrl    String?
  level        Int      @default(1)
  xp           Int      @default(0)
  streak       Int      @default(0)
  longestStreak Int     @default(0)
  lastLoginDate DateTime?
  biggestWin   Float    @default(0)
  favoriteGame String?
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Achievement {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String   @default("🏆")
  xpReward    Int      @default(100)
  trigger     String   // e.g. "games_played:100", "total_won:1000", "streak:7"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
  @@index([userId])
}

model Theme {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  primaryColor String
  secondaryColor String
  accentColor String
  isFree      Boolean  @default(true)
  priceSOL    Float    @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userThemes UserTheme[]
}

model UserTheme {
  id        String   @id @default(cuid())
  userId    String
  themeId   String
  purchasedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme Theme @relation(fields: [themeId], references: [id])

  @@unique([userId, themeId])
  @@index([userId])
}
